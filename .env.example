# --- Mail provider (use either Resend OR SMTP) ---

# Recommended for cloud hosts (Render/Railway/Vercel) - HTTPS API, no SMTP firewall issues.
# Sign up at https://resend.com (free 3k/mo) and paste the API key here.
RESEND_API_KEY=

# Where contact form submissions are delivered.
MAIL_TO=your-email@example.com
MAIL_FROM="Rehman Website <onboarding@resend.dev>"

# --- SMTP fallback (used only when RESEND_API_KEY is empty) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# Frontend optional override:
# REACT_APP_API_URL=http://localhost:5000
